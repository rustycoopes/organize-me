<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Processing Complete</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; line-height: 1.6; color: #333;">
    <!-- Container -->
    <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #e5e7eb;">
        <!-- Header -->
        <div style="background-color: #1f2937; color: #ffffff; padding: 24px; text-align: center;">
            <h1 style="margin: 0; font-size: 24px; font-weight: bold;">OrganizeMe</h1>
            <p style="margin: 8px 0 0 0; font-size: 14px; opacity: 0.9;">Processing Complete</p>
        </div>

        <!-- Content -->
        <div style="padding: 32px;">
            <p style="margin: 0 0 24px 0; font-size: 16px;">
                Hi,
            </p>

            <p style="margin: 0 0 24px 0; font-size: 16px;">
                Your file <strong>{{ filename }}</strong> has been processed successfully.
            </p>

            <!-- Summary Section -->
            <div style="background-color: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin: 24px 0;">
                <p style="margin: 0 0 16px 0; font-size: 14px; font-weight: bold; text-transform: uppercase; color: #6b7280;">
                    Processing Summary
                </p>
                <table style="width: 100%; border-collapse: collapse;">
                    <tr>
                        <td style="padding: 8px 0; border-bottom: 1px solid #d1d5db;">
                            <span style="color: #6b7280; font-size: 14px;">New Events Extracted:</span>
                        </td>
                        <td style="padding: 8px 0; border-bottom: 1px solid #d1d5db; text-align: right;">
                            <span style="font-size: 16px; font-weight: bold; color: #1f2937;">{{ new_event_count }}</span>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 0;">
                            <span style="color: #6b7280; font-size: 14px;">Status:</span>
                        </td>
                        <td style="padding: 8px 0; text-align: right;">
                            <span style="display: inline-block; background-color: #d1fae5; color: #065f46; padding: 4px 12px; border-radius: 4px; font-size: 14px; font-weight: 500;">
                                Success
                            </span>
                        </td>
                    </tr>
                </table>
            </div>

            <p style="margin: 24px 0; font-size: 16px;">
                View your updated dashboard to see all extracted events.
            </p>

            <!-- CTA Button -->
            <div style="text-align: center; margin: 32px 0;">
                <a href="{{ dashboard_url }}" style="display: inline-block; background-color: #1f2937; color: #ffffff; padding: 12px 32px; border-radius: 6px; text-decoration: none; font-weight: bold; font-size: 16px;">
                    Go to Dashboard
                </a>
            </div>

            <p style="margin: 24px 0 0 0; font-size: 14px; color: #6b7280;">
                If you have any questions, please contact us.
            </p>
        </div>

        <!-- Footer -->
        <div style="background-color: #f9fafb; padding: 16px; text-align: center; border-top: 1px solid #e5e7eb;">
            <p style="margin: 0; font-size: 12px; color: #6b7280;">
                OrganizeMe • Automated Event Extraction
            </p>
        </div>
    </div>
</body>
</html>
