# OrganizeMe — local development environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored — never commit it.
# Local dev connects directly to the QA Supabase database and Upstash Redis (no local Docker for either).

# --- App ---
APP_ENV=local
SECRET_KEY=change-me-to-a-random-string
BASE_URL=http://localhost:8000

# --- Cloud Run service URLs (gcloud run services describe <service> --format='value(status.url)') ---
CLOUD_RUN_QA_URL=
CLOUD_RUN_PROD_URL=

# --- Database (Supabase QA) ---
# Use the Session Pooler connection string (Project Settings -> Database -> Connection
# Pooling), not the direct db.<project-ref>.supabase.co host: the direct host is IPv6-only
# and unreachable from networks without an IPv6 route. Pooler host/port vary by project;
# copy the exact string from the dashboard rather than guessing the region.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres

# --- Redis (Upstash, shared local/prod instance) ---
REDIS_URL=rediss://default:<password>@<instance>.upstash.io:6379

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# HS256 (used to sign the JWT auth cookie) wants >= 32 bytes; a short placeholder works for
# local dev but PyJWT will warn on every token it signs.
JWT_SECRET=change-me-to-a-random-string
# false locally so non-browser HTTP clients (curl, httpx) hitting http://localhost can still
# see the Set-Cookie header: real browsers treat localhost as a secure context regardless, but
# httpx's cookie jar checks the request scheme literally and won't resend a Secure cookie over
# plain http. Leave unset (defaults to true) anywhere served over real HTTPS, e.g. Cloud Run.
COOKIE_SECURE=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- LLM ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Storage providers (Google Drive first) ---
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/v1/storage-config/google-drive/callback
# Dropbox app (Slice 8.1) - register at https://www.dropbox.com/developers/apps with a redirect
# URI matching DROPBOX_OAUTH_REDIRECT_URI below.
DROPBOX_OAUTH_CLIENT_ID=
DROPBOX_OAUTH_CLIENT_SECRET=
DROPBOX_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/storage-config/dropbox/callback
# Fernet key that encrypts stored storage-provider credentials at rest (OAuth tokens, S3 keys).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
# Resend's shared sandbox sender works without a verified custom domain, but only delivers
# to the Resend account owner's own verified address. Swap once a custom domain is verified.
EMAIL_FROM=OrganizeMe <onboarding@resend.dev>

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Internal ---
TRIGGER_SCAN_SHARED_SECRET=change-me-to-a-random-string
